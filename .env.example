# Optional but recommended: create an eBay developer app and paste an OAuth bearer token here.
EBAY_BEARER_TOKEN=your_ebay_oauth_bearer_token_here
EBAY_MARKETPLACE_ID=EBAY_US

# Scoring assumptions. Change these to match your real costs.
ESTIMATED_PAYMENT_AND_PLATFORM_FEE_RATE=0.15
ESTIMATED_AD_COST_PER_SALE=5.00
MIN_PROFIT_MARGIN=0.25
